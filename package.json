{
  "name": "jiffy",
  "version": "0.1.0",
  "description": "Local diff reviewer for jj: stacked-bookmark visualization, pierre-powered diffs, and line comments exportable as agent feedback.",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "jiffy": "index.ts"
  },
  "scripts": {
    "build": "bun build index.ts --target bun --outdir dist",
    "dev": "bun --hot index.ts",
    "lint": "bun run typecheck",
    "start": "bun index.ts",
    "test": "bun test",
    "test:e2e": "bun test test/e2e.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright-core": "^1.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@pierre/diffs": "^1.2.9",
    "@pierre/trees": "^1.0.0-beta.4",
    "cmdk": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
