{
  "name": "jiffy",
  "version": "0.1.0",
  "description": "Local diff reviewer for jj: stacked-bookmark visualization, pierre-powered diffs, and line comments exportable as agent feedback.",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "jiffy": "index.ts"
  },
  "scripts": {
    "dev": "bun --hot index.ts",
    "start": "bun index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright-core": "^1.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.9",
    "@pierre/trees": "^1.0.0-beta.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
